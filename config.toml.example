# cc-connect Configuration Example
# This file should be placed at: ~/.cc-connect/config.toml

data_dir = ""
language = "zh"

[[projects]]
  name = "claudecode"

  [projects.agent]
    type = "claudecode"
    [projects.agent.options]
      mode = "default"
      work_dir = "D:/Develop/cc-connect"

  [[projects.platforms]]
    type = "feishu"
    [projects.platforms.options]
      # Replace with your Feishu app credentials
      app_id = "cli_xxxxxxxxxxxx"
      app_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
      # Optional: if you have a static tenant token
      # tenant_access_token = "t-xxxxxxxxxxxxxxxxxxxx"
      # Optional: base URL (default: https://open.feishu.cn)
      # base_url = "https://open.feishu.cn"

[log]
  level = "info"

[speech]
  enabled = false
  provider = ""
  language = ""
  [speech.openai]
    api_key = ""
    base_url = ""
    model = ""
  [speech.groq]
    api_key = ""
