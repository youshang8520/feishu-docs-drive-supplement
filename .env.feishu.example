# 本补丁默认继承 cc-connect 官方配置，无需手动填写此文件
# This supplement inherits cc-connect configuration by default; no manual setup required
#
# 仅在需要覆盖继承值时才设置以下环境变量
# Only set these environment variables if you need to override inherited values
#
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BASE_URL=https://open.feishu.cn
# FEISHU_TIMEOUT_SECONDS=30
# FEISHU_DRY_RUN=false
# FEISHU_TENANT_ACCESS_TOKEN=
